
<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:FleetManager.ViewModels"
             xmlns:models="clr-namespace:FleetManager.Models"
             x:Class="FleetManager.Views.VehicleItemView"
             x:DataType="vm:VehicleItemViewModel">

    <StackPanel Spacing="5">

        <TextBlock Text="{Binding Name}" FontWeight="Bold"/>

        <TextBlock Text="{Binding LicensePlate}"/>

        <TextBlock Text="{Binding Status}"/>

        <TextBlock Text="{Binding FuelLevel, StringFormat='Paliwo: {0}%'}"/>

        <StackPanel Orientation="Horizontal" Spacing="5">

            <Button Content="Tankuj"
                    Command="{Binding RefuelCommand}"/>

            <Button Content="Do Serwisu"
                    Command="{Binding SendToServiceCommand}"/>
            
            <Button Content="W trasie"
                    Command="{Binding SendOnRoadCommand}"/>

        </StackPanel>

    </StackPanel>

</UserControl>