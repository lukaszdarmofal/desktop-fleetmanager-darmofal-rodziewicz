
<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:FleetManager.ViewModels"
             xmlns:models="clr-namespace:FleetManager.Models"
             x:Class="FleetManager.Views.VehicleItemView"
             x:DataType="models:Vehicle">

    <StackPanel Spacing="5">

        <TextBlock Text="{Binding Name}" FontWeight="Bold"/>

        <TextBlock Text="{Binding LicensePlate}"/>

        <TextBlock Text="{Binding Status}"/>

        <TextBlock Text="{Binding FuelLevel, StringFormat='Paliwo: {0}%'}"/>

        <StackPanel Orientation="Horizontal" Spacing="5">

            <Button Content="Tankuj"
                    Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).RefuelCommand}"
                    CommandParameter="{Binding}"/>

            <Button Content="Do Serwisu"
                    Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).SendToServiceCommand}"
                    CommandParameter="{Binding}"/>
            
            <Button Content="W trasie"
                    Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).SendOnRoadCommand}"
                    CommandParameter="{Binding}"/>
                    
                    

        </StackPanel>

    </StackPanel>

</UserControl>